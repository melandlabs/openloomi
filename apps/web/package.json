{
  "name": "web",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/ensure-secrets.js && node ./scripts/run-cross-env.cjs NODE_OPTIONS=\"--max-old-space-size=8192 --require ./scripts/patch-http-timeout.cjs\" PORT=3515 next dev --turbo",
    "dev:monitor": "node ./scripts/ensure-secrets.js && node ./scripts/run-cross-env.cjs NODE_OPTIONS=\"--max-old-space-size=8192 --require ./scripts/patch-http-timeout.cjs\" PORT=3515 next dev --turbo",
    "dev:clean": "node ./scripts/ensure-secrets.js && rimraf .next && node ./scripts/run-cross-env.cjs NODE_OPTIONS=\"--max-old-space-size=8192 --require ./scripts/patch-http-timeout.cjs\" PORT=3515 next dev --turbo",
    "dev:fast": "node ./scripts/ensure-secrets.js && node ./scripts/run-cross-env.cjs SKIP_TYPE_CHECK=true SKIP_ESLINT=true NODE_OPTIONS=\"--max-old-space-size=8192 --require ./scripts/patch-http-timeout.cjs\" PORT=3515 next dev --turbo",
    "dev:webpack": "node ./scripts/ensure-secrets.js && node ./scripts/run-cross-env.cjs SKIP_TYPE_CHECK=true SKIP_ESLINT=true NODE_OPTIONS=\"--max-old-space-size=8192 --require ./scripts/patch-http-timeout.cjs\" PORT=3515 next dev --webpack",
    "dev:webpack:full": "node ./scripts/ensure-secrets.js && node ./scripts/run-cross-env.cjs NODE_OPTIONS=\"--require ./scripts/patch-http-timeout.cjs\" PORT=3515 next dev --webpack",
    "build": "pnpm -C ../.. build:packages && tsx lib/db/migrate && node ./scripts/run-cross-env.cjs NODE_OPTIONS=--max-old-space-size=12288 next build --webpack",
    "build:ci": "pnpm -C ../.. build:packages && tsx lib/db/migrate && node ./scripts/run-cross-env.cjs NODE_OPTIONS=--max-old-space-size=8192 next build",
    "build:turbo": "pnpm -C ../.. build:packages && tsx lib/db/migrate && node ./scripts/run-cross-env.cjs NODE_OPTIONS=--max-old-space-size=8192 next build",
    "build:tauri": "pnpm -C ../.. build:packages && node ./scripts/run-cross-env.cjs IS_TAURI=true NODE_OPTIONS=--max-old-space-size=8192 next build --webpack && node scripts/tauri-build.js",
    "bundle:runtime": "node scripts/bundle-runtime.js",
    "fix:standalone": "node scripts/fix-standalone-pnpm.js",
    "start": "next start",
    "lint": "node ../../node_modules/@biomejs/biome/bin/biome lint",
    "lint:fix": "node ../../node_modules/@biomejs/biome/bin/biome lint --write --unsafe",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,mdx,html,css}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,md,mdx,html,css}\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx lib/db/migrate.ts",
    "db:dump": "npx tsx lib/db/dump.ts",
    "db:migrate:cloud-to-local": "npx tsx lib/db/migrate-cloud-to-local.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up",
    "pretest:unit": "node -e \"const fs=require('node:fs');fs.mkdirSync('coverage/unit/.tmp',{recursive:true});\"",
    "test": "vitest run --coverage",
    "test:benchmark": "tsx tests/benchmark/run-live.ts",
    "tsc": "node ./scripts/run-cross-env.cjs NODE_OPTIONS=--max-old-space-size=8192 node ../../node_modules/typescript/bin/tsc",
    "tauri:dev": "node ./scripts/run-cross-env.cjs IS_TAURI=true PORT=3515 pnpm tauri dev --config src-tauri/tauri.conf.dev.json",
    "tauri:build": "pnpm tauri build && node scripts/optimize-tauri-bundle.js",
    "tauri:build:debug": "node ./scripts/run-cross-env.cjs IS_TAURI=true SKIP_TYPE_CHECK=true NODE_OPTIONS=--max-old-space-size=8192 tsx lib/db/migrate && next build && pnpm tauri build && node scripts/optimize-tauri-bundle.js",
    "db:generate:sqlite": "drizzle-kit generate --config=drizzle.config.sqlite.ts"
  },
