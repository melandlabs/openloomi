# openssl rand -base64 32
AUTH_SECRET=****

# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ENCRYPTION_KEY=****

# Agent base url and token
ANTHROPIC_BASE_URL=****
ANTHROPIC_API_KEY=****
ANTHROPIC_AUTH_TOKEN=****
ANTHROPIC_MODEL=****

# Cloud API Configuration for Tauri Desktop App
# Tauri version uses cloud API for user authentication and data sync
# Set to your cloud server address (e.g., https://app.openloomi.ai)
# Leave empty or commented out to disable cloud authentication (fully local mode)
CLOUD_API_URL=****
NEXT_PUBLIC_CLOUD_API_URL=****

# Get your OpenAI-Compatible API Key here for insights/events.
#
# For cloud deployment:
# - LLM_API_KEY is used for direct access to the AI provider (OpenAI/OpenRouter/etc.)
# - This is the actual API key from your AI provider
#
# For local development:
# - LLM_API_KEY is not required
# - The system will use user JWT tokens for authentication
# - All requests are proxied through the cloud for unified billing
LLM_BASE_URL=****
LLM_API_KEY=****
LLM_MODEL=****
LLM_VISION_LANGUAGE_MODEL=****
LLM_IMAGE_MODEL=****

# Embedding model for RAG (Knowledge Base) functionality
# IMPORTANT: You need an API key that supports embeddings!
# Option 1: Use OpenAI directly (recommended for embeddings)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_EMBEDDINGS_API_KEY=sk-...
# LLM_EMBEDDING_BASE_URL=https://api.openai.com/v1
# LLM_EMBEDDING_MODEL=text-embedding-3-small
#
# Option 2: Use OpenRouter (may require additional permissions)
# Note: Not all OpenRouter accounts have embeddings access
# OPENAI_EMBEDDINGS_API_KEY=sk-or-v1-...
# LLM_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# LLM_EMBEDDING_MODEL=openai/text-embedding-3-small
#
# If not configured, RAG upload will fail with a clear error message
OPENAI_EMBEDDINGS_API_KEY=****

# OpenAI Audio API (Whisper + TTS)
# OpenRouter does not support audio APIs, so we use OpenAI directly
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=****
# Optional: Custom base URL for OpenAI Audio API (defaults to https://api.openai.com/v1)
# OPENAI_AUDIO_BASE_URL=https://api.openai.com/v1
LLM_EMBEDDING_BASE_URL=****
LLM_EMBEDDING_MODEL=****

# Brave Search API (optional) - Get API key from https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=****

# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/storage/vercel-postgres/quickstart
POSTGRES_URL=****

# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=****

# Default telegram bot token name and token (optional, just for test)
TG_BOT_NAME=****
TG_BOT_TOKEN=****
TG_SESSION=****

# Telegram Bot Mode: webhook or polling
# - webhook: Telegram sends updates to your server (requires public URL)
# - polling: Polls Telegram messages for updates (works on localhost)
TELEGRAM_MODE=polling

# Webhook mode configuration (when TELEGRAM_MODE=webhook)
# Optional: secret used to validate Telegram webhook requests
TELEGRAM_WEBHOOK_SECRET_TOKEN=****

# Polling mode configuration (when TELEGRAM_MODE=polling)
# Polling interval in milliseconds (default: 1000)
TELEGRAM_POLLING_INTERVAL=1000
# Long polling timeout in seconds (default: 30)
TELEGRAM_POLLING_TIMEOUT=30

# Optional: overrides for building public Telegram links on the web
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=****
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/YourBotUsername

# Telegram App Id and Hash. Reference: https://my.telegram.org/
TG_APP_ID=****
TG_APP_HASH=****

# Twitter (X) OAuth - Get credentials from https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=****
TWITTER_CLIENT_SECRET=****
# Production environment remote callback URL
TWITTER_REDIRECT_URI=****

# Default slack token (optional, just for test)
SLACK_BOT_TOKEN=****
SLACK_USER_TOKEN=****
SLACK_APP_TOKEN=****
SLACK_SIGNING_SECRET=****

# Slack App Id and secret
SLACK_CLIENT_ID=****
SLACK_CLIENT_SECRET=****
SLACK_SOCKET_MODE=****

# Discord OAuth credentials and bot configuration
DISCORD_CLIENT_ID=****
DISCORD_CLIENT_SECRET=****
DISCORD_BOT_TOKEN=****
DISCORD_GUILD_ID=****
DISCORD_PUBLIC_KEY=****

NEXT_PUBLIC_DISCORD_CLIENT_ID=****

# Google client id
GOOGLE_CLIENT_ID=****
GOOGLE_CLIENT_SECRET=****
# Default google access token (optional, just for test)
GOOGLE_ACCESS_TOKEN=****
# Google App password (optional, just for test)
GOOGLE_APP_PASSWORD=****
GOOGLE_GMAIL_ADDRESS=****

# Gmail OAuth Integration
# Enable Gmail OAuth authorization method in the frontend (set to "true" to enable)
NEXT_PUBLIC_GMAIL_OAUTH_ENABLED=false
# Gmail OAuth client ID (create at https://console.cloud.google.com/)
GMAIL_CLIENT_ID=****
# Gmail OAuth client secret
GMAIL_CLIENT_SECRET=****
# Optional: OAuth redirect URI (defaults to https://<app>/api/gmail/callback)
# GMAIL_REDIRECT_URI=https://your-domain.com/api/gmail/callback

# App URL
NEXT_PUBLIC_APP_URL=****

